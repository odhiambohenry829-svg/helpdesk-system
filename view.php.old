<?php
include 'db.php';

$result = $conn->query("SELECT * FROM issues");
?>

<h2>Reported Issues</h2>

<table border="1">
<tr>
<th>ID</th>
<th>Name</th>
<th>Department</th>
<th>Issue</th>
<th>Status</th>
<th>Action</th>
</tr>

<?php
while($row = $result->fetch_assoc()) {
    echo "<tr>
    <td>{$row['id']}</td>
    <td>{$row['name']}</td>
    <td>{$row['department']}</td>
    <td>{$row['issue']}</td>
    <td>{$row['status']}</td>
    <td><a href='update.php?id={$row['id']}'>Update</a></td>
    </tr>";
}
?>
</table>